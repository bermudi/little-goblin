# Copy to ~/.config/goblin/.env (prod) or .env (dev) and fill in.

# --- Telegram ---
# BotFather token.
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the goblin.
# Find yours by DMing @userinfobot.
ALLOWED_TG_USER_IDS=

# --- Model ---
# Set at least one key. MODEL_NAME picks which provider+model is used;
# see src/agent/models.ts for the full table.
#
# Poe models (recommended):
#   Claude-Sonnet-4.6, Claude-Haiku-4.5  (Messages API, prompt caching)
#   GPT-5, GPT-5-mini                    (Responses API, reasoning)
#   Gemini-2.5-Pro                       (Chat Completions)
#
# OpenRouter models (use slash-slugs):
#   anthropic/claude-sonnet-4.5, openai/gpt-5, ...
POE_API_KEY=
OPENROUTER_API_KEY=
MODEL_NAME=Claude-Sonnet-4.6

# --- Goblin state dir ---
# Where AGENTS.md, skills/, sessions/ live. Default: ~/goblin
GOBLIN_HOME=

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info
