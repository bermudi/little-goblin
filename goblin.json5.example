// Copy to ~/goblin/goblin.json5 (or $GOBLIN_HOME/goblin.json5) and fill in.
{
  // --- Telegram ---
  // BotFather token. Can be literal, env var name, or shell command.
  // botToken: "!pass show bots/goblin",  // get from password store
  // botToken: "BOT_TOKEN",               // read from env var
  botToken: "your-bot-token-here",

  // Telegram user IDs allowed to talk to the goblin. At least one required.
  // Find yours by DMing @userinfobot.
  allowedUsers: [123456789],

  // --- Model ---
  // MODEL uses prefixed IDs to pick provider. Set the matching API key.
  // Format: <provider>/<model-id>
  //
  // Poe (recommended):
  //   poe/Claude-Sonnet-4.6, poe/Claude-Haiku-4.5  (Messages API, prompt caching)
  //   poe/GPT-5, poe/GPT-5-mini                    (Responses API)
  //   poe/Gemini-2.5-Pro                            (Chat Completions)
  //
  // OpenRouter:
  //   or/anthropic/claude-sonnet-4.5, or/openai/gpt-5, ...
  //
  // Direct providers:
  //   openai/gpt-5.4, openai/gpt-5.4-mini, openai/o4
  //   anthropic/claude-opus-4, anthropic/claude-sonnet-4.6
  //   zai/glm-5.2, zai/glm-5.1  (Z.AI Coding Plan, Chat Completions)
  model: "poe/Claude-Sonnet-4.6",

  // API keys. Set whichever your model needs. Values support env var names
  // and !commands just like botToken.
  // poeApiKey: "POE_API_KEY",
  // openrouterApiKey: "!pass-cli item view 'pass://Keys/OpenRouter/Api Key'",
  // openaiApiKey: "OPENAI_API_KEY",
  // anthropicApiKey: "ANTHROPIC_API_KEY",
  // zaiApiKey: "ZAI_API_KEY",

  // --- Favorite Models (for /model switching) ---
  // List model IDs you switch between often. Use /model to list and switch.
  favorites: [
    "poe/Claude-Sonnet-4.6",
    "openai/gpt-5.4",
    "anthropic/claude-sonnet-4.6",
    "zai/glm-5.2",
    "zai/glm-5.1",
  ],

  // --- Logging ---
  // debug | info | warn | error
  logLevel: "info",

  // --- UI ---
  // Tool-call visibility in the status line:
  //   none     no status line
  //   minimal  state-changing tools only (bash, write, edit, spawn_subagent)
  //   standard all α tools (default)
  //   verbose  α + γ tools (revive_subagent, list_subagents)
  //   debug    everything
  toolVisibility: "standard",
}
