# Copy to ~/.config/goblin/.env (prod) or .env (dev) and fill in.

# --- Telegram ---
# BotFather token.
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the goblin.
# Find yours by DMing @userinfobot.
ALLOWED_TG_USER_IDS=

# --- Model ---
# MODEL_NAME uses prefixed IDs to pick provider. Set the matching API key.
# Format: <provider>/<model-id>
#
# Poe (recommended):
#   poe/Claude-Sonnet-4.6, poe/Claude-Haiku-4.5  (Messages API, prompt caching)
#   poe/GPT-5, poe/GPT-5-mini                    (Responses API)
#   poe/Gemini-2.5-Pro                            (Chat Completions)
#
# OpenRouter:
#   or/anthropic/claude-sonnet-4.5, or/openai/gpt-5, ...
#
# Direct providers:
#   openai/gpt-5.4, openai/gpt-5.4-mini, openai/o4
#   anthropic/claude-opus-4, anthropic/claude-sonnet-4.6
#
# Set whichever key your MODEL_NAME needs:
POE_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_NAME=poe/Claude-Sonnet-4.6

# --- Goblin state dir ---
# Where AGENTS.md, skills/, sessions/ live. Default: ~/goblin
GOBLIN_HOME=

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info
