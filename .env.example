# Copy to ~/.config/goblin/.env (prod) or .env (dev) and fill in.

# --- Telegram ---
# BotFather token.
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the goblin.
# Find yours by DMing @userinfobot.
ALLOWED_TG_USER_IDS=

# --- Model (OpenAI-compatible: Poe, OpenRouter, etc.) ---
# Poe:        https://api.poe.com/v1
# OpenRouter: https://openrouter.ai/api/v1
MODEL_BASE_URL=https://openrouter.ai/api/v1
MODEL_API_KEY=
MODEL_NAME=anthropic/claude-sonnet-4.5

# --- Goblin state dir ---
# Where AGENTS.md, skills/, sessions/ live. Default: ~/goblin
GOBLIN_HOME=

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info
