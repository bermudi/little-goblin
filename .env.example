# Copy to .env for dev convenience.
#
# Configuration lives in goblin.json5 (see goblin.json5.example).
# This file only sets env vars referenced by the config file.
#
# For prod installs, set env vars directly or use:
#   bun --env-file=$GOBLIN_ENV_FILE ...

# BotFather token (or reference in goblin.json5)
BOT_TOKEN=

# API keys referenced by goblin.json5:
# POE_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ZAI_API_KEY=
# GROQ_API_KEY=   # Optional: enables Telegram voice-note transcription (Groq Whisper)

# Optional: overrides goblin.json5 voiceName for Edge TTS (/voice, text_to_speech)
# VOICE_NAME=en-US-AndrewMultilingualNeural
