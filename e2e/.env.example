# Goblin E2E smoke suite — environment variables.
# Copy to e2e/.env (or export in your shell) and fill in.
# Get api_id and api_hash from https://my.telegram.org/apps.

# --- Required ---
E2E_API_ID=123456
E2E_API_HASH=your_api_hash_here
# Goblin's bot username (without @) or numeric bot user id.
E2E_GOBLIN=goblin_bot

# --- Optional: target chat ---
# Defaults to goblin's DM. Set to test in a different chat.
# E2E_CHAT=

# --- Optional: forum topic test ---
# E2E_FORUM_CHAT=my_forum_supergroup
# E2E_FORUM_TOPIC_ID=create   # or a specific topic id integer

# --- Optional: file round-trip test ---
# E2E_PROJECT_DIR=/tmp/goblin-e2e-project

# --- Optional: voice test (requires Edge TTS: uvx edge-tts) ---
# E2E_VOICE=1

# --- Optional: MCP tool-call test ---
# Either set these two:
# E2E_MCP_PROBE_PROMPT=Use the mcp_call tool to call myserver.get_time, then reply with the result.
# E2E_MCP_PROBE_EXPECT=2025
# Or set E2E_MCP_PROBE as JSON:
# E2E_MCP_PROBE={"prompt":"...","expect":"..."}

# --- Optional: timing tuning ---
# E2E_TIMEOUT_MS=180000       # agent reply timeout (default 180s)
# E2E_SETTLE_MS=2500          # stream settle window (default 2500ms)
# E2E_COMMAND_TIMEOUT_MS=30000 # system reply timeout (default 30s)

# --- Optional: test filtering ---
# E2E_ONLY=ping,help          # run only these tests (comma-separated)
# E2E_SKIP=voice,forum-topic  # skip these tests (comma-separated)
